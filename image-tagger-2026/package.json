    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.6",
    "tailwind-merge": "^3.5.0",
